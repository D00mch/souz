+static void ggml_metal_configure_compile_options(ggml_metal_device_t dev, MTLCompileOptions * options) {
+#if TARGET_OS_OSX && __MAC_OS_X_VERSION_MAX_ALLOWED >= 260000
+    if (ggml_metal_device_get_props(dev)->has_tensor) {
+        if (@available(macOS 26.0, iOS 26.0, tvOS 26.0, visionOS 2.0, *)) {
+            options.languageVersion = MTLLanguageVersion4_0;
+            return;
+        }
+    }
+#endif
+
+#if TARGET_OS_OSX && __MAC_OS_X_VERSION_MAX_ALLOWED >= 140000
+    if (ggml_metal_device_get_props(dev)->has_bfloat) {
+        if (@available(macOS 14.0, iOS 17.0, tvOS 17.0, visionOS 1.0, *)) {
+            options.languageVersion = MTLLanguageVersion3_1;
+            return;
+        }
+    }
+#endif
+
+    GGML_UNUSED(dev);
+    GGML_UNUSED(options);
+}
